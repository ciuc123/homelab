# Example environment file for create-subdomain workflow
# Copy to .env when testing locally. DO NOT commit real secrets.

# REQUIRED
CF_API_TOKEN=            # Cloudflare API token with DNS edit permissions (use "Edit zone DNS" template or permissions: Zone.Zone (read), Zone.DNS (edit)).
CF_ZONE_ID=              # Cloudflare Zone ID for your domain (e.g. from Dashboard > Overview)
CF_ZONE_NAME=            # Your zone name (e.g. ciuculescu.com)
GH_PAT=                  # GitHub Personal Access Token with 'repo' scope (and 'workflow' if needed). For org repos, ensure proper org permissions.
GH_OWNER=                # GitHub owner (user or org) where new repos will be created

# OPTIONAL
TEMPLATE_REPO=           # Optional template repo name to generate from (if set, workflow tries to use it)
TEMPLATE_OWNER=          # Owner of template repo (defaults to authenticated actor)

# OPTIONAL - for local testing only
ISSUE_NUMBER=            # (optional) issue number to post back a comment to
ISSUE_REPO=              # (optional) owner/repo string (used with ISSUE_NUMBER)

# NOTES
# - Create the GitHub repo secret at: Repo -> Settings -> Secrets and variables -> Actions -> New repository secret
# - Create CF token in Cloudflare Dashboard -> My Profile -> API Tokens
# - Never store secrets in plaintext in the repository
